# SQLx compile-time verification database
# This is used by the sqlx-cli to verify queries at compile time
# The actual runtime database path is determined by the application
DATABASE_URL=sqlite:crates/core/.sqlx-dev.db
# This ensuers that the sqlx macros uses the perpared offline data
# in .sqlx dir. To regenrate, run sqlx prepare --all --workspace
SQLX_OFFLINE=true
