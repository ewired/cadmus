{
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "minimumReleaseAge": "7 days",
  "labels": ["automated", "dependencies"],
  "reviewers": ["OGKevin"],
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["cargo", "custom.regex"],
      "matchDepNames": ["rumdl"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Rust non-major dependencies",
      "groupSlug": "rust-non-major"
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchJsonata": ["isBreaking != true"],
      "groupName": "Rust non-major dependencies",
      "groupSlug": "rust-non-major"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "GitHub Actions non-major dependencies",
      "groupSlug": "github-actions-non-major"
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": ["@mermaid-js/mermaid-cli", "prettier"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "JavaScript tooling non-major dependencies",
      "groupSlug": "js-tooling-non-major"
    },
    {
      "description": "stylelint and stylelint-config-standard must stay in sync via peer dependencies",
      "matchManagers": ["npm"],
      "matchPackageNames": ["stylelint", "stylelint-config-standard"],
      "groupName": "stylelint",
      "groupSlug": "stylelint"
    },
    {
      "description": "Git submodules use git-refs, which has no releaseTimestamp; exempt from minimumReleaseAge",
      "matchManagers": ["git-submodules"],
      "minimumReleaseAge": null,
      "addLabels": ["thirdparty"]
    },
    {
      "description": "Keep mdbook-i18n-helpers submodule and devenv.nix fetchFromGitHub pin in sync",
      "matchManagers": ["git-submodules", "custom.regex"],
      "matchPackageNames": [
        "thirdparty/mdbook-i18n-helpers",
        "ogkevin/mdbook-i18n-helpers"
      ],
      "groupName": "mdbook-i18n-helpers",
      "groupSlug": "mdbook-i18n-helpers"
    },
    {
      "description": "Keep mupdf submodule and version pins in sync",
      "matchManagers": ["git-submodules", "custom.regex"],
      "matchSourceUrls": ["https://github.com/ArtifexSoftware/mupdf"],
      "matchDepNames": ["thirdparty/mupdf"],
      "groupName": "mupdf",
      "groupSlug": "mupdf",
      "addLabels": ["thirdparty"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/actions\\/rumdl-lint\\/action\\.yml$/"
      ],
      "matchStrings": [
        "rumdl_version:[\\s\\S]*?default: \"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "crate",
      "depNameTemplate": "rumdl",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/actions\\/install-doc-tools\\/action\\.yml$/"
      ],
      "matchStrings": ["MDBOOK_VERSION=(?<currentValue>[^\"]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "rust-lang/mdBook",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/actions\\/install-doc-tools\\/action\\.yml$/"
      ],
      "matchStrings": ["MDBOOK_EPUB_REV=(?<currentValue>[a-f0-9]{40})"],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "Michael-F-Bryan/mdbook-epub",
      "packageNameTemplate": "https://github.com/Michael-F-Bryan/mdbook-epub",
      "versioningTemplate": "git"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/actions\\/install-doc-tools\\/action\\.yml$/"
      ],
      "matchStrings": ["MDBOOK_MERMAID_VERSION=(?<currentValue>[^\"]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "badboy/mdbook-mermaid",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/actions\\/install-doc-tools\\/action\\.yml$/"
      ],
      "matchStrings": ["ZOLA_VERSION=(?<currentValue>[^\"]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "getzola/zola",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^devenv\\.nix$/"],
      "matchStrings": [
        "owner = \"Michael-F-Bryan\";\\s*\\n\\s*repo = \"mdbook-epub\";\\s*\\n\\s*rev = \\\"(?<currentValue>[a-f0-9]{40})\\\""
      ],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "Michael-F-Bryan/mdbook-epub",
      "packageNameTemplate": "https://github.com/Michael-F-Bryan/mdbook-epub",
      "versioningTemplate": "git"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^devenv\\.nix$/"],
      "matchStrings": [
        "owner = \"ogkevin\";\\s*\\n\\s*repo = \"mdbook-i18n-helpers\";\\s*\\n\\s*rev = \\\"(?<currentValue>[a-f0-9]{40})\\\""
      ],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "ogkevin/mdbook-i18n-helpers",
      "packageNameTemplate": "https://github.com/ogkevin/mdbook-i18n-helpers",
      "versioningTemplate": "git"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/cadmus-docs\\.yml$/",
        "/^\\.github\\/workflows\\/cargo\\.yml$/",
        "/^\\.github\\/workflows\\/release\\.yml$/",
        "/^\\.github\\/workflows\\/build-release-candidate\\.yml$/",
        "/^\\.github\\/workflows\\/copilot-setup-steps\\.yml$/"
      ],
      "matchStrings": ["NODE_VERSION:\\s+\\\"(?<currentValue>[^\\\"]+)\\\""],
      "datasourceTemplate": "node-version",
      "depNameTemplate": "node",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github\\/workflows\\/cargo\\.yml$/"],
      "matchStrings": ["NEXTEST_VERSION:\\s+\\\"(?<currentValue>[^\\\"]+)\\\""],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "nextest-rs/nextest",
      "extractVersionTemplate": "^cargo-nextest-(?<version>.+)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^xtask\\/src\\/tasks\\/bundle\\.rs$/"],
      "matchStrings": [
        "NICKEL_VERSION: &str = \\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "pgaskin/NickelMenu",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^xtask\\/src\\/tasks\\/download_assets\\.rs$/"],
      "matchStrings": [
        "PLATO_VERSION: &str = \\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "baskerville/plato",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^crates\\/build-deps\\/src\\/versions\\.rs$/"],
      "matchStrings": [
        "MUPDF_VERSION: &str = \\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "thirdparty/mupdf",
      "packageNameTemplate": "ArtifexSoftware/mupdf",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^crates\\/core\\/src\\/document\\/mupdf_sys\\.rs$/"
      ],
      "matchStrings": [
        "pub const FZ_VERSION: &str = \\\"(?<currentValue>[^\\\"]+)\\\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "thirdparty/mupdf",
      "packageNameTemplate": "ArtifexSoftware/mupdf",
      "versioningTemplate": "semver"
    }
  ]
}
